{
  "manifest_version": 2,
  "name": "BF Companion Utilities",
  "version": "1.0",
  "description": "Full-featured toolkit for the Battlefield Companion Emblem Editor: rotation handle, precise position/size controls, undo/redo, alignment tools, and reference image overlay.",

  "permissions": [
    "https://companion.battlefield.com/*"
  ],

  "content_scripts": [
    {
      "matches": ["https://companion.battlefield.com/*"],
      "js": ["inject.js"],
      "run_at": "document_start",
      "all_frames": true
    }
  ],

  "browser_action": {
    "default_icon": "icon.png",
    "default_title": "BF Companion Utilities"
  },

  "browser_specific_settings": {
    "gecko": {
      "id": "bf-emblem-rotate-fix@local.test",
      "strict_min_version": "140.0",
      "data_collection_permissions": {
        "required": ["none"]
      }
    }
  }
}